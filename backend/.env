# ══════════════════════════════════════════════
# GraphRAG Platform — Environment Configuration
# ══════════════════════════════════════════════

APP_ENV=development

# ── Application ──
PROJECT_NAME="GraphRAG Platform"
VERSION="1.0.0"
DEBUG=true
API_V1_STR=/api/v1

# ── CORS ──
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# ── JWT ──
JWT_SECRET_KEY=graphrag-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# ── Ollama (LLM Serving) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.1
OLLAMA_NUM_CTX=4096
MAX_TOKENS=2048

# ── Neo4j (Graph DB) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# ── Qdrant (Vector DB) ──
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION=graphrag_documents
QDRANT_VECTOR_SIZE=1024

# ── PostgreSQL (Sessions) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graphrag_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# ── Logging ──
LOG_DIR=logs
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# ── OpenTelemetry ──
OTEL_ENABLED=true
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=graphrag-backend

# ── Security ──
GUARDRAILS_ENABLED=true
MAX_INPUT_LENGTH=10000
PROMPT_INJECTION_THRESHOLD=0.85

# ── GraphRAG Pipeline ──
CHUNK_SIZE=512
CHUNK_OVERLAP=64
ENTITY_EXTRACTION_BATCH_SIZE=5
GRAPH_COMMUNITY_ALGORITHM=louvain
RERANKER_TOP_K=5

# ── Email (SMTP) ──
# For real SMTP (Gmail/Yandex): set SMTP_USER, SMTP_PASSWORD
# Leave empty to use local Mailpit at http://localhost:8025
SMTP_HOST=mailpit
SMTP_PORT=1025
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=false

# ── Paths ──
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
